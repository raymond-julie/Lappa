# Generated by Lappa - ROS2 Humble Hawksbill
# Loads ROS2 distro, colcon, and launch stack for real package builds.
FROM ros:humble-ros-base

ENV DEBIAN_FRONTEND=noninteractive
ENV ROS_DISTRO=humble
ENV LANG=C.UTF-8

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3-pip \
    python3-colcon-common-extensions \
    python3-rosdep \
    build-essential \
    ros-humble-rclpy \
    ros-humble-launch \
    ros-humble-launch-ros \
    ros-humble-std-msgs \
    ros-humble-geometry-msgs \
    ros-humble-sensor-msgs \
    ros-humble-nav-msgs \
    ros-humble-robot-state-publisher \
    ros-humble-tf2-ros \
    ros-humble-slam-toolbox \
    ros-humble-xacro \
    ros-humble-ros2cli \
    ros-humble-ros2launch \
    ros-humble-ros2pkg \
    ros-humble-ros2run \
    ros-humble-ros2node \
    ros-humble-ros2topic \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /ws
# Demo packages bind-mount here: /ws/src/<pkg>
RUN mkdir -p /ws/src /ws/log /ws/build /ws/install
COPY entrypoint.sh /entrypoint.sh
COPY ros2_ws.sh /ros2_ws.sh
RUN sed -i 's/\r$//' /entrypoint.sh /ros2_ws.sh && chmod +x /entrypoint.sh /ros2_ws.sh

ENTRYPOINT ["/entrypoint.sh"]
# Keep ROS sourced; sleep so IDE can docker-exec colcon + ros2 launch
CMD ["bash", "-lc", "source /opt/ros/humble/setup.bash && echo \"[lappa] ROS2 humble loaded; workspace /ws; demos at /ws/src\" && sleep infinity"]
