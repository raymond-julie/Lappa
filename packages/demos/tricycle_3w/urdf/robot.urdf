<?xml version="1.0"?>
<!-- Lappa aligned 3D robot - package tricycle_3w -->
<robot name="tricycle_3w">
  <link name="base_footprint"/>
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.14000" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://tricycle_3w/meshes/tricycle_3w_chassis.obj" scale="1 1 1"/>
      </geometry>
      <material name="lappa_mesh">
        <color rgba="0.2 0.55 0.95 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://tricycle_3w/meshes/tricycle_3w_chassis.obj" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <link name="wheel_steer">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://tricycle_3w/meshes/tricycle_3w_wheel_steer.obj" scale="1 1 1"/>
      </geometry>
      <material name="lappa_mesh">
        <color rgba="0.15 0.15 0.18 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://tricycle_3w/meshes/tricycle_3w_wheel_steer.obj" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <joint name="wheel_steer_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_steer"/>
    <origin xyz="0.25000 0.00000 -0.05500" rpy="0 0 0.00000"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="wheel_rear_l">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://tricycle_3w/meshes/tricycle_3w_wheel_rear_l.obj" scale="1 1 1"/>
      </geometry>
      <material name="lappa_mesh">
        <color rgba="0.15 0.15 0.18 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://tricycle_3w/meshes/tricycle_3w_wheel_rear_l.obj" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <joint name="wheel_rear_l_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_rear_l"/>
    <origin xyz="-0.13000 0.15000 -0.04000" rpy="0 0 0.00000"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="wheel_rear_r">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://tricycle_3w/meshes/tricycle_3w_wheel_rear_r.obj" scale="1 1 1"/>
      </geometry>
      <material name="lappa_mesh">
        <color rgba="0.15 0.15 0.18 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://tricycle_3w/meshes/tricycle_3w_wheel_rear_r.obj" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <joint name="wheel_rear_r_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_rear_r"/>
    <origin xyz="-0.13000 -0.15000 -0.04000" rpy="0 0 0.00000"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://tricycle_3w/meshes/tricycle_3w_lidar.obj" scale="1 1 1"/>
      </geometry>
      <material name="lappa_mesh">
        <color rgba="0.95 0.55 0.2 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://tricycle_3w/meshes/tricycle_3w_lidar.obj" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.00000 0.00000 0.16000" rpy="0 0 0"/>
  </joint>

</robot>
