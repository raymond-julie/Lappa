<?xml version="1.0"?>
<robot name="diff_drive_2w">
  <link name="base_link"/>
  <!-- Simplified URDF placeholder for Lappa canvas / future mesh load -->
  <link name="wheel_left"/>
  <link name="wheel_right"/>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://diff_drive_2w/meshes/unit_wheel.obj" scale="1 1 1"/>
      </geometry>
      <material name="lappa_mesh">
        <color rgba="0.2 0.55 0.95 1"/>
      </material>
    </visual>
